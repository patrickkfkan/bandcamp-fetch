{
  "name": "bandcamp-fetch",
  "version": "2.0.0-node14-compat",
  "description": "Scrape Bandcamp content",
  "scripts": {
    "build": "rm -rf dist && npm run build:esm && npm run build:cjs && bash fixup.sh",
    "build:esm": "npx tsc -p tsconfig-esm.json",
    "build:cjs": "npx tsc -p tsconfig.json"
  },
  "main": "./dist/cjs/index-cjs.js",
  "module": "./dist/mjs/index.js",
  "types": "./dist/mjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/mjs/index.d.ts",
        "default": "./dist/mjs/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index-cjs.js"
      }
    }
  },
  "author": "Patrick Kan <patrickkfkan@gmail.com> (https://github.com/patrickkfkan)",
  "repository": {
    "type": "git",
    "url": "https://github.com/patrickkfkan/bandcamp-fetch.git"
  },
  "license": "MIT",
  "directories": {
    "dist": "./dist"
  },
  "engines": {
    "node": ">=14"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/node-fetch": "^2.6.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "bottleneck": "^2.19.5",
    "cheerio": "1.0.0-rc.12",
    "html-entities": "^2.5.2",
    "node-cache": "^5.1.2",
    "node-fetch": "^2.6.9"
  },
  "keywords": [
    "bandcamp",
    "scrape",
    "scraper",
    "discover",
    "album",
    "track",
    "artist"
  ]
}
